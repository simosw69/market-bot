# Environment variables for the usato aggregator bot

# Database
DATABASE_URL=sqlite:///./data/annunci.db

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Search terms (comma-separated)
SEARCH_TERMS=smartphone,laptop,bicicletta,vestiti,arredamento

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Other settings
# SCRAPE_INTERVAL_MINUTES=30 (already set in code)